# LaunchDarkly Configuration
# Get your client-side ID from: https://app.launchdarkly.com/settings/projects
VITE_LD_CLIENT_SIDE_ID=your-client-side-id-here

# Feature flag key to evaluate
VITE_LD_FLAG_KEY=sample-feature

# Observability Configuration
# Get your project ID from LaunchDarkly Observability settings
VITE_LD_OBSERVABILITY_PROJECT_ID=your-project-id-here

# Weather API Configuration
# Get your API key from https://www.weatherapi.com/
VITE_WEATHER_API_KEY=your-weather-api-key-here
