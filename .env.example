# LaunchDarkly Configuration
# Get your client-side ID from: https://app.launchdarkly.com/settings/projects
VITE_LD_CLIENT_SIDE_ID=your-client-side-id-here

# Feature flag key for temperature units (true = Fahrenheit, false = Celsius)
# Make sure this flag exists in your LaunchDarkly project
VITE_LD_FLAG_KEY=sample-feature

# Weather API Configuration (Optional)
# Get your free API key from https://www.weatherapi.com/
# If not provided, the app will use mock weather data
VITE_WEATHER_API_KEY=your-weather-api-key-here
